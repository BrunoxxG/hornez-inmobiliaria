generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id      String @id @default(cuid())
  name    String
  phone   String
  address String

  @@map("company")
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

model User {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  password String
  role     Role    @default(USER)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("users")
}