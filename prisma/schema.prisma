// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String
  role     Role   @default(USER)

  properties Property[]

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("users")
}

model ListingType {
  id   String @id @default(cuid())
  name String
  slug String @unique

  properties Property[]

  @@map("listing_types")
}

model PropertyType {
  id   String @id @default(cuid())
  name String
  slug String @unique

  properties Property[]

  @@map("property_types")
}

enum Currency {
  USD
  ARS
}

enum PropertyStatus {
  AVAILABLE @map("Disponible")
  RESERVED  @map("Reservado")
  SOLD      @map("Vendido")
  RENTED    @map("Alquilado")
}

model Property {
  id          String  @id @default(cuid())
  title       String
  description String
  price       Decimal @db.Decimal(12, 2)

  listingTypeId String
  listingType   ListingType @relation(fields: [listingTypeId], references: [id])

  propertyTypeId String
  propertyType   PropertyType @relation(fields: [propertyTypeId], references: [id])

  address  String
  city     String
  province String
  zipCode  String

  totalRooms Int
  bedrooms   Int
  bathrooms  Int
  area       Float

  currency Currency @default(USD)

  lat Float
  lng Float

  status PropertyStatus @default(AVAILABLE)
  active Boolean        @default(true)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  images Image[]
  video  String

  features PropertyFeature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city])
  @@index([price])
  @@index([listingTypeId])
  @@index([propertyTypeId])
  @@index([bedrooms])
  @@index([bathrooms])
  @@index([status])
  @@map("properties")
}

model Feature {
  id   String @id @default(cuid())
  name String

  properties PropertyFeature[]

  @@map("features")
}

model PropertyFeature {
  id    String @id @default(cuid())
  value String @default("-")

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  featureId String
  feature   Feature @relation(fields: [featureId], references: [id])

  @@unique([propertyId, featureId])
  @@map("property_features")
}

model Image {
  id    String @id @default(cuid())
  url   String
  order Int?   @default(0)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, order])
  @@map("property_images")
}
